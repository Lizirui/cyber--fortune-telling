# 赛博算命 - 智能合约环境变量配置
# ============================================
# 使用方式:
#   Sepolia: cp .env.sepolia .env
#   主网:    cp .env.mainnet .env
# ============================================

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base 主网 RPC
BASE_RPC_URL=https://mainnet.base.org

# 部署私钥 (不要提交到 Git!)
PRIVATE_KEY=

# 授权签名者地址 (用于验证后端签名)
AUTHORIZED_SIGNER=

# BaseScan API Key
BASESCAN_API_KEY=
