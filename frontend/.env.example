# 后端 API 地址
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# NFT 合约地址 (部署后填写)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# WalletConnect 项目 ID
# 演示用 ID，生产环境请替换为真实的 projectId
# 获取方式: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=a4d4ab2e2e26c55f4ebc54e5d8a7e5c

# ========== Vercel 部署环境变量 ==========
# 以下变量只在 Vercel 后端运行时需要，前端不需要

# DeepSeek API 密钥 (用于 AI 生成祝福语)
DEEPSEEK_API_KEY=

# 签名私钥 (用于 Mint 签名验证)
SIGNER_PRIVATE_KEY=

# Base Sepolia RPC URL
BASE_RPC_URL=

# Vercel KV (Redis) 存储
# 在 Vercel Dashboard -> Storage -> Create KV Database
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
